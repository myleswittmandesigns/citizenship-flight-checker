# ─────────────────────────────────────────────────────────────
# Google OAuth 2.0
# 1. Go to https://console.cloud.google.com/
# 2. APIs & Services → Credentials → Create OAuth 2.0 Client ID
# 3. Application type: Web application
# 4. Authorized redirect URIs — add BOTH:
#      Local dev:       http://localhost:8501
#      Streamlit Cloud: https://citizenship-flight-checker.streamlit.app
# 5. Enable the Gmail API for your project
# ─────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# ─────────────────────────────────────────────────────────────
# Anthropic Claude API Key
# https://console.anthropic.com/
# ─────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ─────────────────────────────────────────────────────────────
# App Configuration
# ─────────────────────────────────────────────────────────────
# Must match an Authorized Redirect URI in Google Cloud Console
# Local dev:
REDIRECT_URI=http://localhost:8501
# Streamlit Cloud (set this in Streamlit secrets, not .env):
# REDIRECT_URI=https://citizenship-flight-checker.streamlit.app
